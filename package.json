{
  "name": "gym-familly-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:herd",
    "dev:herd": "vite",
    "dev:fallback": "concurrently \"npm:backend:serve\" \"vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "backend:serve": "php backend/artisan serve --host=127.0.0.1 --port=8000",
    "backend:migrate": "php backend/artisan migrate",
    "backend:fresh": "php backend/artisan migrate:fresh --seed",
    "backend:test": "php backend/artisan test",
    "backend:herd:link": "powershell -NoProfile -Command \"Set-Location 'backend'; & 'C:\\Program Files\\Herd\\resources\\app.asar.unpacked\\resources\\bin\\herd.bat' link backend --update-env\""
  },
  "dependencies": {
    "concurrently": "^10.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.15.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-legacy": "^8.1.0",
    "@vitejs/plugin-react": "^5.1.1",
    "terser": "^5.48.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  }
}
